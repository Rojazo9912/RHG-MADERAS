# ── Supabase ──────────────────────────────────────────────────────────────
# Panel de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica
# ¡Secreta! Solo se usa en el servidor (app/api). Nunca la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# ── Email (Resend) ───────────────────────────────────────────────────────
# https://resend.com — reemplaza los nodos de Email de n8n.
RESEND_API_KEY=tu_resend_api_key
EMAIL_FROM_NOTIFICACIONES="RHG Maderas <notificaciones@rhgmaderas.com>"
EMAIL_FROM_COTIZACIONES="RHG Maderas <cotizaciones@rhgmaderas.com>"
EMAIL_EQUIPO=Roberto.herrera.garcia8@gmail.com

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://rhgmaderas.com

# ── Google Sheets (respaldo opcional) ────────────────────────────────────
# URL del webhook que recibe cada lead nuevo y lo agrega a tu hoja de cálculo.
# Puede ser un Apps Script doPost, un workflow de Make/Zapier, etc.
# Si se deja vacía, el respaldo simplemente no se activa (no afecta la app).
GOOGLE_SHEETS_WEBHOOK_URL=
